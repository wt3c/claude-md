# Claude Code Environment Variables
# Copie para .env e preencha com valores reais

# GitLab (MPRJ)
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_API_URL=https://gitlab-dti.mprj.mp.br/api/v4

# PostgreSQL (desenvolvimento)
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/database

# Infisical
INFISICAL_TOKEN=st.xxxxxxxxxxxxxxxxxxxx
INFISICAL_PROJECT_ID=xxxxxxxxxxxxxxxxxxxx
INFISICAL_ENVIRONMENT=development

# Dynatrace
DYNATRACE_API_TOKEN=dt0c01.xxxxxxxxxxxxxxxxxxxx
DYNATRACE_API_URL=https://your-environment.live.dynatrace.com/api

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=my-service

# Django (se aplicável)
SECRET_KEY=your-secret-key-here
DEBUG=True
DATABASE_URL=postgresql://user:password@localhost:5432/database

# PySpark / Hadoop (se aplicável)
SPARK_HOME=/opt/spark
HADOOP_HOME=/opt/hadoop
HADOOP_CONF_DIR=/etc/hadoop/conf
