# Infisical — credenciais de conexão (não são secrets da aplicação)
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env (já está no .gitignore)

INFISICAL_PROJECT_ID=your-project-id-here
INFISICAL_TOKEN=st.your-service-token-here
INFISICAL_SITE_URL=https://your-infisical-instance.com/
INFISICAL_PORT=80

# Ambiente: dev | staging | prod
INFISICAL_ENVIRONMENT_SLUG=dev

# Secrets esperados no Infisical:
# - ANTHROPIC_FOUNDRY_API_KEY (sk-ant-...)
# - GITLAB_TOKEN (glpat-...)
# - POSTMAN_API_KEY (PMAK-...)
