{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Read(**/*)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(uv *)",
      "Bash(python manage.py *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Write(src/**/*)",
      "Write(apps/**/*)",
      "Write(tests/**/*)",
      "Write(docs/**/*)",
      "Write(tasks/**/*)",
      "Write(.claude/**/*)",
      "Edit(src/**/*)",
      "Edit(apps/**/*)",
      "Edit(tests/**/*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Write(/etc/*)",
      "Write(~/.ssh/*)",
      "Write(~/.aws/*)",
      "Write(.env)",
      "Write(**/*.env)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== Git Status ===' && git status --short && echo '\n=== Recent Commits ===' && git log --oneline -5"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(*.py)",
        "hooks": [
          {
            "type": "command",
            "command": "ruff check \"$CLAUDE_FILE_PATH\" --fix && ruff format \"$CLAUDE_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Edit(*.py)",
        "hooks": [
          {
            "type": "command",
            "command": "ruff check \"$CLAUDE_FILE_PATH\" --fix && ruff format \"$CLAUDE_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Write(apps/**/*.py)",
        "hooks": [
          {
            "type": "command",
            "command": "mypy \"$CLAUDE_FILE_PATH\" || echo 'Mypy check completed with warnings'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --cached --name-only | grep -E '\\.(env|key|pem|p12)$' && echo 'WARNING: Attempting to commit secrets!' && exit 1 || exit 0"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "gitlab": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gitlab"],
      "env": {
        "GITLAB_TOKEN": "${GITLAB_TOKEN}",
        "GITLAB_API_URL": "https://gitlab-dti.mprj.mp.br/api/v4"
      }
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_CONNECTION_STRING}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${PWD}"
      ]
    }
  },
  "sandbox": {
    "enabled": false
  }
}
